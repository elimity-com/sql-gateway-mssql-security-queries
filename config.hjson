                    "name": "Authentication Type",
                    "type": "string"
                },
                {
                    "description": "",
                    "id": "createdAt",
                    "name": "Created at",
                    "type": "dateTime"
                },
                {
                    "description": "",
                    "id": "database",
                    "name": "Database",
                    "type": "string"
                },
                {
                    "description": "",
                    "id": "lastModifiedAt",
                    "name": "Last modified at",
